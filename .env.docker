# Variáveis de ambiente para o ambiente Docker local
# Copie este arquivo para .env (ou use diretamente) ao rodar docker-compose

# JWT secret (troque em produção)
JWT_SECRET=minha-chave-secreta-local

# Gemini API key — obtenha em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# As demais variáveis (DATABASE_URL, CORS_ORIGIN, PORT) já estão definidas no docker-compose.yml