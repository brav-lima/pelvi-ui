generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// Organization (Clínica / Tenant)
// ──────────────────────────────────────────────

enum ClinicAccessStatus {
  ACTIVE
  BLOCKED
}

enum DocumentType {
  CNPJ
  CPF
}

model Organization {
  id           String             @id @default(uuid())
  name         String
  document     String?            @unique @map("cnpj")
  documentType DocumentType?      @map("document_type")
  email        String?
  phone        String?
  settings        Json?
  accessStatus    ClinicAccessStatus @default(ACTIVE) @map("access_status")
  planMaxUsers    Int?               @map("plan_max_users")
  planMaxPatients Int?               @map("plan_max_patients")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  users            OrganizationUser[]
  patients         Patient[]
  procedures       Procedure[]
  appointments     Appointment[]
  anamneses        Anamnesis[]
  perinealAssessments PerinealAssessment[]
  evolutions       Evolution[]
  financialRecords FinancialRecord[]
  treatmentPackages TreatmentPackage[]

  @@map("organizations")
}

// ──────────────────────────────────────────────
// Person (global user, identified by CPF)
// ──────────────────────────────────────────────

model Person {
  id           String   @id @default(uuid())
  cpf          String   @unique
  name         String
  email        String   @unique
  phone        String?
  passwordHash String   @map("password_hash")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organizationUsers OrganizationUser[]
  refreshTokens     RefreshToken[]

  @@map("persons")
}

// ──────────────────────────────────────────────
// RefreshToken — refresh tokens com rotação
// Apenas o hash do jti é persistido; o JWT em claro vive somente no cookie httpOnly
// ──────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(uuid())
  personId  String    @map("person_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ──────────────────────────────────────────────
// OrganizationUser (Person ↔ Organization link)
// ──────────────────────────────────────────────

enum Role {
  ADMIN
  PROFESSIONAL
  RECEPTIONIST
}

model OrganizationUser {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  personId       String   @map("person_id")
  role           Role     @default(PROFESSIONAL)
  permissions    Json?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  person       Person       @relation(fields: [personId], references: [id])

  appointments Appointment[]
  anamneses    Anamnesis[]
  perinealAssessments PerinealAssessment[]
  evolutions   Evolution[]

  @@unique([organizationId, personId])
  @@map("organization_users")
}

// ──────────────────────────────────────────────
// Patient
// ──────────────────────────────────────────────

model Patient {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  cpf            String?
  birthDate      DateTime? @map("birth_date")
  email          String?
  phone          String?
  gender              String?
  addressCep          String?  @map("address_cep")
  addressStreet       String?  @map("address_street")
  addressNumber       String?  @map("address_number")
  addressComplement   String?  @map("address_complement")
  addressNeighborhood String?  @map("address_neighborhood")
  addressCity         String?  @map("address_city")
  addressState        String?  @map("address_state")
  notes               String?
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization     Organization      @relation(fields: [organizationId], references: [id])
  appointments     Appointment[]
  anamneses        Anamnesis[]
  perinealAssessments PerinealAssessment[]
  evolutions       Evolution[]
  financialRecords FinancialRecord[]
  treatmentPackages TreatmentPackage[]

  @@index([organizationId, deletedAt])
  @@index([organizationId, name, deletedAt])
  @@map("patients")
}

// ──────────────────────────────────────────────
// Procedure
// ──────────────────────────────────────────────

model Procedure {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  name            String
  durationMinutes Int      @map("duration_minutes")
  price           Decimal  @db.Decimal(10, 2)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization              Organization               @relation(fields: [organizationId], references: [id])
  appointments              Appointment[]
  treatmentPackageProcedures TreatmentPackageProcedure[]

  @@map("procedures")
}

// ──────────────────────────────────────────────
// Appointment (Agenda)
// ──────────────────────────────────────────────

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELED
  DONE
}

model Appointment {
  id                 String            @id @default(uuid())
  organizationId     String            @map("organization_id")
  patientId          String            @map("patient_id")
  professionalId     String            @map("professional_id")
  procedureId        String            @map("procedure_id")
  treatmentPackageId String?           @map("treatment_package_id")
  startAt            DateTime          @map("start_at")
  endAt              DateTime          @map("end_at")
  status             AppointmentStatus @default(SCHEDULED)
  notes              String?
  deletedAt          DateTime?         @map("deleted_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  organization     Organization       @relation(fields: [organizationId], references: [id])
  patient          Patient            @relation(fields: [patientId], references: [id])
  professional     OrganizationUser   @relation(fields: [professionalId], references: [id])
  procedure        Procedure          @relation(fields: [procedureId], references: [id])
  treatmentPackage TreatmentPackage?  @relation(fields: [treatmentPackageId], references: [id])
  evolutions       Evolution[]
  financialRecords FinancialRecord[]

  @@index([organizationId, startAt, endAt, deletedAt])
  @@index([organizationId, professionalId, startAt, deletedAt])
  @@index([organizationId, patientId, deletedAt])
  @@map("appointments")
}

// ──────────────────────────────────────────────
// Anamnesis
// ──────────────────────────────────────────────

model Anamnesis {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  patientId      String   @map("patient_id")
  professionalId String   @map("professional_id")
  data           Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id])
  patient      Patient          @relation(fields: [patientId], references: [id])
  professional OrganizationUser @relation(fields: [professionalId], references: [id])

  @@index([organizationId, patientId])
  @@index([organizationId, createdAt])
  @@map("anamneses")
}

// ──────────────────────────────────────────────
// PerinealAssessment
// Avaliação Cinesiológico-Funcional do Assoalho Pélvico (perineo.net)
// ──────────────────────────────────────────────

model PerinealAssessment {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  patientId      String   @map("patient_id")
  professionalId String   @map("professional_id")
  data           Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id])
  patient      Patient          @relation(fields: [patientId], references: [id])
  professional OrganizationUser @relation(fields: [professionalId], references: [id])

  @@index([organizationId, patientId])
  @@index([organizationId, createdAt])
  @@map("perineal_assessments")
}

// ──────────────────────────────────────────────
// Evolution
// ──────────────────────────────────────────────

model Evolution {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  patientId      String   @map("patient_id")
  professionalId String   @map("professional_id")
  appointmentId  String?  @map("appointment_id")
  description    String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id])
  patient      Patient          @relation(fields: [patientId], references: [id])
  professional OrganizationUser @relation(fields: [professionalId], references: [id])
  appointment  Appointment?     @relation(fields: [appointmentId], references: [id])

  @@index([organizationId, patientId])
  @@index([organizationId, createdAt])
  @@map("evolutions")
}

// ──────────────────────────────────────────────
// AuditLog
// ──────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  action         String
  entity         String
  entityId       String?  @map("entity_id")
  details        Json?
  ipAddress      String?  @map("ip_address")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ──────────────────────────────────────────────
// FinancialRecord
// ──────────────────────────────────────────────

enum FinancialType {
  INCOME
  EXPENSE
}

enum FinancialStatus {
  PENDING
  PAID
}

model FinancialRecord {
  id                 String          @id @default(uuid())
  organizationId     String          @map("organization_id")
  patientId          String?         @map("patient_id")
  appointmentId      String?         @map("appointment_id")
  treatmentPackageId String?         @map("treatment_package_id")
  amount             Decimal         @db.Decimal(10, 2)
  type               FinancialType
  status             FinancialStatus @default(PENDING)
  paymentMethod      String?         @map("payment_method")
  description        String?
  dueDate            DateTime?       @map("due_date")
  installment        Int?
  installmentTotal   Int?            @map("installment_total")
  deletedAt          DateTime?       @map("deleted_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  organization     Organization      @relation(fields: [organizationId], references: [id])
  patient          Patient?          @relation(fields: [patientId], references: [id])
  appointment      Appointment?      @relation(fields: [appointmentId], references: [id])
  treatmentPackage TreatmentPackage? @relation(fields: [treatmentPackageId], references: [id])

  @@index([organizationId, createdAt, deletedAt])
  @@index([organizationId, status, type, deletedAt])
  @@map("financial_records")
}

// ──────────────────────────────────────────────
// TreatmentPackage (Pacote de Tratamento)
// ──────────────────────────────────────────────

enum TreatmentPackageStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

model TreatmentPackage {
  id             String                 @id @default(uuid())
  organizationId String                 @map("organization_id")
  patientId      String                 @map("patient_id")
  name           String
  totalSessions  Int                    @map("total_sessions")
  usedSessions   Int                    @default(0) @map("used_sessions")
  totalPrice     Decimal                @db.Decimal(10, 2) @map("total_price")
  status         TreatmentPackageStatus @default(ACTIVE)
  notes          String?
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  organization     Organization               @relation(fields: [organizationId], references: [id])
  patient          Patient                    @relation(fields: [patientId], references: [id])
  procedures       TreatmentPackageProcedure[]
  appointments     Appointment[]
  financialRecords FinancialRecord[]

  @@index([organizationId, patientId])
  @@index([organizationId, createdAt])
  @@map("treatment_packages")
}

model TreatmentPackageProcedure {
  id                 String @id @default(uuid())
  treatmentPackageId String @map("treatment_package_id")
  procedureId        String @map("procedure_id")

  treatmentPackage TreatmentPackage @relation(fields: [treatmentPackageId], references: [id], onDelete: Cascade)
  procedure        Procedure        @relation(fields: [procedureId], references: [id])

  @@unique([treatmentPackageId, procedureId])
  @@map("treatment_package_procedures")
}
