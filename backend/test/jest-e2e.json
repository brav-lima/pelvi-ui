{
  "moduleFileExtensions": ["js", "json", "ts", "tsx"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)sx?$": ["ts-jest", {
      "tsconfig": {
        "module": "commonjs",
        "moduleResolution": "node",
        "resolvePackageJsonExports": false,
        "jsx": "react-jsx"
      }
    }]
  },
  "moduleNameMapper": {
    "^@react-pdf/renderer$": "<rootDir>/mocks/react-pdf.mock.js"
  },
  "testTimeout": 30000,
  "forceExit": true
}
