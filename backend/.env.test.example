# Copy this file to .env.test and fill in values for your test database.
# This file is loaded when NODE_ENV=test (e2e tests).
# Use a SEPARATE database from dev/prod — tests create and delete real records.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pelvi_test
JWT_SECRET=test-jwt-secret-min-32-chars-not-for-production
JWT_REFRESH_SECRET=test-jwt-refresh-secret-min-32-chars-not-for-production
CORS_ORIGIN=http://localhost:8080
INTERNAL_API_KEY=test-internal-api-key-min-32-chars-long-here
