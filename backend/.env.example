# Local:   DATABASE_URL=postgresql://user:password@localhost:5432/pelvi
# Supabase (Transaction Pooler, porta 6543 — app runtime):
#   DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://user:password@localhost:5432/pelvi

# Supabase (conexão direta, porta 5432 — Prisma migrations only):
#   DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DIRECT_URL=
JWT_SECRET=your-jwt-secret-here
# Segredo distinto para refresh tokens — rotacione separadamente do access secret.
JWT_REFRESH_SECRET=your-refresh-secret-here
CORS_ORIGIN=http://localhost:8080
PORT=3000
