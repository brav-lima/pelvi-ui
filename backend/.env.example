# Local:   DATABASE_URL=postgresql://user:password@localhost:5432/pelvi
# Supabase (Transaction Pooler, porta 6543 — app runtime):
#   DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://user:password@localhost:5432/pelvi

# Supabase (conexão direta, porta 5432 — Prisma migrations only):
#   DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DIRECT_URL=
JWT_SECRET=your-jwt-secret-here
# Segredo distinto para refresh tokens — rotacione separadamente do access secret.
JWT_REFRESH_SECRET=your-refresh-secret-here
CORS_ORIGIN=http://localhost:8080
PORT=3000
# Segredo compartilhado para autenticação M2M com o pelvi-admin.
# Deve ser idêntico ao CLINIC_INTERNAL_API_KEY do pelvi-admin.
# Gerar: openssl rand -base64 32
INTERNAL_API_KEY=
# Canal clinic→admin: pelvi-ui chama pelvi-admin como proxy para dados de assinatura.
# ADMIN_API_URL — URL base do pelvi-admin (sem trailing slash).
# ADMIN_EXTERNAL_API_KEY — segredo enviado no header x-clinic-api-key.
#   Deve ser idêntico ao CLINIC_EXTERNAL_API_KEY do pelvi-admin.
#   Gerar: openssl rand -base64 32
ADMIN_API_URL=http://localhost:3001
ADMIN_EXTERNAL_API_KEY=
# Redis — usar redis://redis:6379 no Docker Compose, redis://localhost:6379 em dev local
REDIS_URL=redis://localhost:6379
# Sentry APM (opcional — no-op se ausente)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
