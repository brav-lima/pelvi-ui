# Variáveis usadas pelo docker-compose.yml do pelvi-ui.
# Copie para `.env` (mesma pasta) e preencha antes de subir.

# ─── Banco de dados ──────────────────────────────
# Dev local (container postgres do docker compose) — use no backend/.env.dev:
DATABASE_URL=postgresql://pelvi:pelvi@localhost:5432/pelvi
DIRECT_URL=postgresql://pelvi:pelvi@localhost:5432/pelvi
# ATENÇÃO: quando o backend roda DENTRO do docker compose, não defina essas vars
# no .env raiz — o default já aponta para postgres:5432 (nome do serviço).
#
# Supabase (Transaction Pooler, porta 6543 — app runtime):
#   DATABASE_URL=postgresql://postgres.[REF]:[PASS]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# Supabase (conexão direta, porta 5432 — Prisma migrations only):
#   DIRECT_URL=postgresql://postgres:[PASS]@db.[REF].supabase.co:5432/postgres

# ─── Segredos JWT ────────────────────────────────
JWT_SECRET=clinic-dev-jwt-secret-change-me
JWT_REFRESH_SECRET=clinic-dev-refresh-secret-change-me

# ─── Integração com pelvi-admin ──────────────────
# Deve ser o mesmo valor que CLINIC_INTERNAL_API_KEY no pelvi-admin.
INTERNAL_API_KEY=shared-internal-api-key-change-me-min-32-chars
