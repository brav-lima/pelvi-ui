#!/usr/bin/env sh

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "${YELLOW}▶ Lint...${NC}"
if ! bun run lint --quiet; then
  echo "${RED}✗ Lint falhou. Corrija os erros antes de commitar.${NC}"
  exit 1
fi
echo "${GREEN}✓ Lint OK${NC}"
echo ""

echo "${YELLOW}▶ Testes...${NC}"
if ! bun run test; then
  echo "${RED}✗ Testes falharam. Corrija antes de commitar.${NC}"
  exit 1
fi
echo "${GREEN}✓ Testes OK${NC}"
echo ""

echo "${GREEN}✓ Tudo certo — commit liberado.${NC}"
